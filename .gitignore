# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# If you find yourself ignoring temporary files generated by your text editor
# or operating system, you probably want to add a global ignore instead:
#   git config --global core.excludesfile '~/.gitignore_global'

*.rdb

# Ignore bundler config.
/.bundle

# Ignore the default SQLite database.
/db/*.sqlite3
/db/*.sqlite3-journal

# Ignore all logfiles and tempfiles.
/log/*.log
/tmp

/config/application.yml
/config/application_settings/aws.yml
/config/aws.yml
/config/database.yml
/config/moysklad.yml
/config/redis.yml
/config/osmicards.yml
.idea/
.vagrant/

.DS_Store
.rvmrc
/public/uploads
/public/assets
/public/test_uploads
/coverage

*.sublime-project
*.sublime-workspace

.sass-cache/

product_modification.log

/public/sitemap*.xml
/public/avito
/public/google
/public/facebook
/public/yandex*
/public/marketplace
/public/exports/*.csv
/public/mindbox
/public/vkontakte

/lib/tasks/ignore_tasks
